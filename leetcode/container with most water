class Solution:
    def maxArea(self, height: List[int]) -> int:
        left = 0
        right = len(height) - 1
        max_val = 0
        
        while left < right:
            # 1. Calculate current area
            # The height is limited by the shorter bar
            current_area = min(height[left], height[right]) * (right - left)
            
            # 2. Update max_val if current_area is larger
            if current_area > max_val:
                max_val = current_area
            
            # 3. Move the pointer of the shorter bar
            if height[left] < height[right]:
                left += 1
            else:
                right -= 1
        
        # 4. Return after the loop has checked all pairs
        return max_val
        
