class Solution:
    def numRescueBoats(self, people: list[int], limit: int) -> int:
        # 1. Sort the people by weight
        people.sort()
        
        left = 0                  # Pointer for the lightest person
        right = len(people) - 1   # Pointer for the heaviest person
        boats = 0
        
        while left <= right:
            # 2. Check if the lightest and heaviest can share a boat
            if people[left] + people[right] <= limit:
                # If they fit, move the 'left' pointer to the next lightest person
                left += 1
            
            # 3. The heaviest person always takes a boat
            # (either shared with 'left' or alone)
            right -= 1
            boats += 1
            
        return boats
