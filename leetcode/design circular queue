class MyCircularQueue:
    def __init__(self, k: int):
        self.queue = [0] * k
        self.capacity = k
        self.head = 0
        self.count = 0

        

    def enQueue(self, value: int) -> bool:
        if self.isFull(): return False

        target_idx = (self.head + self.count) % self.capacity
        self.queue[target_idx] = value
        self.count += 1
        return True
        

    def deQueue(self) -> bool:
        if self.isEmpty(): return False
        # Move head forward using modulo
        self.head = (self.head + 1) % self.capacity
        self.count -= 1
        return True
        

    def Front(self) -> int:
      return -1 if self.isEmpty() else self.queue[self.head]
        

    def Rear(self) -> int:
        if self.isEmpty(): return -1
        # Rear is always count-1 steps away from head
        rear_idx = (self.head + self.count - 1) % self.capacity
        return self.queue[rear_idx]
        

    def isEmpty(self) -> bool:
        return self.count == 0
        

    def isFull(self) -> bool:
        return self.count == self.capacity
        



