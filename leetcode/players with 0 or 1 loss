class Solution:
    def findWinners(self, matches: list[list[int]]) -> list[list[int]]:
        # Count losses for every player
        losses = Counter()
        
        # We also need to track winners who never lost
        # By setting them to 0 if they don't exist in losses yet
        for winner, loser in matches:
            if winner not in losses:
                losses[winner] = 0
            losses[loser] += 1
            
        zero_loss = []
        one_loss = []
        
        # Categorize based on loss count
        for player, count in losses.items():
            if count == 0:
                zero_loss.append(player)
            elif count == 1:
                one_loss.append(player)
        
        # Return sorted results
        return [sorted(zero_loss), sorted(one_loss)]
