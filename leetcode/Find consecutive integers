from collections import deque
class DataStream:
    def __init__(self, value: int, k: int):
        self.queue = deque()
        self.limit = value
        self.k = k
        self.counter = 0 
    def consec(self, num: int) -> bool:
        if len(self.queue) < self.k:
            self.queue.append(num)
            if num == self.limit:
                self.counter += 1
            if len(self.queue) == self.k and self.counter == self.k:
                return True
            return False
        else:
            if num == self.limit:
                self.counter += 1
            pop_value = self.queue.popleft()
            self.queue.append(num)
            if pop_value == self.limit:
                self.counter -=1
            return self.counter == self.k
            
            


