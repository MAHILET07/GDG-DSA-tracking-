class Solution:
    def firstBadVersion(self, n: int) -> int:
        left = 1
        right = n
        
        while left < right:
            # Prevent potential overflow in some languages
            mid = left + (right - left) // 2
            
            if isBadVersion(mid):
                # This could be the first bad version
                # Look at the left side, but keep mid as a candidate
                right = mid
            else:
                # This version is good, so the first bad must be after it
                left = mid + 1
        
        # When left == right, we've found the first bad version
        return left
        
